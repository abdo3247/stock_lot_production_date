<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Transferts — onglet "Opérations détaillées" (stock.move.line).
        On ajoute production_date via lot_id.production_date en lecture seule.
    -->
    <record id="view_production_date_stock_picking_form" model="ir.ui.view">
        <field name="name">stock.picking.form.production.date</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <!-- Colonne date de production dans les lignes détaillées -->
            <xpath expr="//field[@name='move_line_ids_without_package']//field[@name='lot_id']" position="after">
                <field name="lot_production_date" string="Date prod." optional="show" readonly="1"/>
            </xpath>
        </field>
    </record>

</odoo>
