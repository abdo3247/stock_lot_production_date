<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Liste des emplacements de stock (Inventaire → Produits → Emplacements).
        Base : stock.view_stock_quant_tree_editable
        product_expiry y ajoute expiration_date à priority=16. Notre vue à priority=20.
    -->
    <record id="view_quant_tree_production_date" model="ir.ui.view">
        <field name="name">stock.quant.list.production.date</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_editable"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='expiration_date']" position="before">
                <field name="lot_production_date"
                       string="Date prod."
                       optional="show"
                       readonly="1"/>
            </xpath>
        </field>
    </record>

    <!--
        Liste inventaire physique (Inventaire → Opérations → Inventaire physique).
        Base : stock.view_stock_quant_tree_inventory_editable
    -->
    <record id="view_quant_inventory_tree_production_date" model="ir.ui.view">
        <field name="name">stock.quant.inventory.list.production.date</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_inventory_editable"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='expiration_date']" position="before">
                <field name="lot_production_date"
                       string="Date prod."
                       optional="show"
                       readonly="1"/>
            </xpath>
        </field>
    </record>

</odoo>
