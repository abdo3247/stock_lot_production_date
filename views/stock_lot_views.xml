<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Formulaire : hérite de stock.view_production_lot_form (priority=10).
        product_expiry.view_move_form_expiry ajoute expiration_date à priority=16.
        Notre vue s'applique à priority=20 pour trouver expiration_date dans l'arch.
    -->
    <record id="view_lot_production_date_form" model="ir.ui.view">
        <field name="name">stock.lot.form.production.date</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='expiration_date']" position="before">
                <field name="production_date" widget="date"/>
            </xpath>
        </field>
    </record>

    <!-- Liste : colonne production_date optionnelle avant expiration_date -->
    <record id="view_lot_production_date_tree" model="ir.ui.view">
        <field name="name">stock.lot.tree.production.date</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='expiration_date']" position="before">
                <field name="production_date" optional="show"/>
            </xpath>
        </field>
    </record>

    <!--
        Kanban : hérite de stock.view_production_lot_kanban (priority=10).
        product_expiry.view_production_lot_view_kanban ajoute expiration_date à priority=16.
        Notre vue s'applique à priority=20.
    -->
    <record id="view_lot_production_date_kanban" model="ir.ui.view">
        <field name="name">stock.lot.kanban.production.date</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_kanban"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='expiration_date']" position="before">
                <field name="production_date"/>
            </xpath>
        </field>
    </record>

    <!-- Recherche : filtre par date + group_by -->
    <record id="view_lot_production_date_search" model="ir.ui.view">
        <field name="name">stock.lot.search.production.date</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.search_product_lot_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <filter
                    string="Date de production"
                    name="filter_production_date"
                    date="production_date"/>
                <filter
                    string="Par date de production"
                    name="groupby_production_date"
                    context="{'group_by': 'production_date'}"/>
            </xpath>
        </field>
    </record>

</odoo>
