<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Formulaire du lot : ajout date de production dans le groupe des dates -->
    <record id="view_production_date_stock_lot_form" model="ir.ui.view">
        <field name="name">stock.lot.form.production.date</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_lot_form"/>
        <field name="arch" type="xml">
            <!--
                Dans Odoo 19, le groupe des dates d'expiration contient expiration_date.
                On insère production_date avant expiration_date.
            -->
            <xpath expr="//field[@name='expiration_date']" position="before">
                <field name="production_date" widget="date"/>
            </xpath>
        </field>
    </record>

    <!-- Vue liste des lots : colonne date de production -->
    <record id="view_production_date_stock_lot_tree" model="ir.ui.view">
        <field name="name">stock.lot.tree.production.date</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_lot_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='expiration_date']" position="before">
                <field name="production_date" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
