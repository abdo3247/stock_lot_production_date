<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Regex appliqué au name du lot (vide = parsing désactivé).
             Groupes nommés supportés : dop (date of production), doe (date of expiry).
             Exemple : (?P<dop>\d{6})-(?P<doe>\d{6})  -->
        <record id="param_lot_name_regex" model="ir.config_parameter">
            <field name="key">stock_lot_production_date.lot_name_regex</field>
            <field name="value"></field>
        </record>

        <!-- Format strptime des dates extraites par le regex (défaut %y%m%d = AAMMJJ). -->
        <record id="param_lot_date_format" model="ir.config_parameter">
            <field name="key">stock_lot_production_date.lot_date_format</field>
            <field name="value">%y%m%d</field>
        </record>

    </data>
</odoo>
